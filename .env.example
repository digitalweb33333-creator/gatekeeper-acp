# ---- GATEKEEPER ACP — environment (copy to .env, never commit .env) ----
PORT=10000
PUBLIC_BASE_URL=https://gatekeeper-acp.onrender.com

# ---- ACP v2 seller wiring (blank until provided; service runs without them) ----
WHITELISTED_WALLET_PRIVATE_KEY=
SELLER_ENTITY_ID=
SELLER_AGENT_WALLET_ADDRESS=
SELLER_BUILDER_CODE=
ACP_RPC_URL=

# ---- Optional ----
# honeypot.is is keyless; GoPlus is keyless. No keys required.
EXTRA_RPCS=
# Daily re-check interval for approval_monitor (ms). Default 24h.
MONITOR_INTERVAL_MS=86400000
